# Use "mock" to run the interface without access to Finnegans.
DATA_SOURCE=mock

# PostgreSQL connection supplied by Finnegans Data Warehouse.
DATABASE_URL=postgresql://readonly_user:password@warehouse.example.com:5432/database
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
DATABASE_POOL_MAX=5
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_IDLE_TIMEOUT_MS=30000
TICKET_CACHE_TTL_SECONDS=3600
SUMMARY_CACHE_TTL_SECONDS=3600
TICKET_MAX_ROWS=100000

# Use this adapter for the Finnegans relationship dataset discovered in this project.
# Leave empty to use the generic canonical column mapping below.
TICKET_ADAPTER=
# Optional: leave empty to include every ticket process.
TICKET_PROCESS=

# Source table/view and canonical column mapping.
TICKETS_TABLE=public.analytics_tickets
TICKET_ID_COLUMN=ticket_id
TICKET_TITLE_COLUMN=title
TICKET_CREATED_AT_COLUMN=created_at
TICKET_FIRST_RESPONSE_AT_COLUMN=first_response_at
TICKET_RESOLVED_AT_COLUMN=resolved_at
TICKET_STATUS_COLUMN=status
TICKET_PRIORITY_COLUMN=priority
TICKET_CATEGORY_COLUMN=category
TICKET_CUSTOMER_COLUMN=customer
TICKET_TEAM_COLUMN=team
TICKET_ASSIGNEE_COLUMN=assignee
TICKET_SLA_BREACHED_COLUMN=sla_breached
TICKET_UPDATED_AT_COLUMN=updated_at
TERMINAL_STATUSES=Resuelto,Cerrado,Cancelado
